FROM quay.io/toolbx/arch-toolbox:latest AS base

# makepkg/paru cannot be executed as root, so add a regular user for building
RUN useradd -u 2000 -d /var/build -m -g wheel builder && chmod 755 /var/build && echo "builder ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

FROM base AS build

# Install paru to enable AUR repository usage
RUN pacman -Syu --needed --noconfirm rust && sudo -u builder -H sh -c "cd && rm -rf paru-git && git clone https://aur.archlinux.org/paru.git paru-git && cd paru-git && makepkg -s --noconfirm && ls -l"

FROM base
RUN --mount=type=bind,target=/var/build/paru-git,from=build,source=/var/build/paru-git \
    pacman -U --noconfirm /var/build/paru-git/paru-2.1.0-2-x86_64.pkg.tar.zst

RUN curl -L -o /usr/bin/host-spawn https://github.com/1player/host-spawn/releases/download/v1.6.2/host-spawn-x86_64 && \
    chmod +x /usr/bin/host-spawn

COPY host-exec.sh /usr/bin/host-exec
